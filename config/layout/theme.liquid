<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LUNE — Lingerie de Luxe</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Josefin+Sans:wght@100;300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0b0909;--gold:#c9a96e;--rose:#8b3a52;--cream:#f5efe8;
  --mid:#1a1414;--dark2:#100c0c;--muted:#6a5858;--muted2:#3a2a2a;
  --light:#f5efe8;
}
html{scroll-behavior:smooth}
body{background:var(--bg);font-family:'Josefin Sans',sans-serif;color:var(--cream);overflow-x:hidden;cursor:none}
 
/* ─ CURSOR ─ */
.cur{width:7px;height:7px;border-radius:50%;background:var(--gold);position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .2s,height .2s}
.cur-ring{width:32px;height:32px;border-radius:50%;border:1px solid rgba(201,169,110,.35);position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:transform .22s ease}
body:hover .cur{opacity:1}
 
/* ─ PAGE SYSTEM ─ */
.page{display:none;animation:pgIn .45s ease}
.page.active{display:block}
@keyframes pgIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
 
/* ─ NAV ─ */
nav{position:fixed;top:0;left:0;right:0;z-index:200;height:68px;display:flex;align-items:center;justify-content:space-between;padding:0 52px;transition:background .4s,backdrop-filter .4s}
nav.scrolled,nav.solid{background:rgba(11,9,9,.92);backdrop-filter:blur(16px);border-bottom:1px solid rgba(201,169,110,.08)}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:300;letter-spacing:.42em;color:var(--cream);text-decoration:none;cursor:none}
.nav-links{display:flex;gap:34px;list-style:none}
.nav-links a{font-size:.5rem;letter-spacing:.38em;color:#666;text-decoration:none;transition:color .3s;cursor:none;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.nav-links a:hover,.nav-links a.active-nav{color:var(--cream)}
.nav-links a:hover::after,.nav-links a.active-nav::after{transform:scaleX(1)}
.nav-right{display:flex;align-items:center;gap:22px}
.nav-icon{background:none;border:none;color:#666;font-size:.85rem;cursor:none;transition:color .3s;padding:6px;position:relative}
.nav-icon:hover{color:var(--gold)}
.cart-count{position:absolute;top:0;right:0;width:14px;height:14px;border-radius:50%;background:var(--rose);font-size:.38rem;display:flex;align-items:center;justify-content:center;color:white;font-family:'Josefin Sans',sans-serif}
 
/* ─ ANNOUNCEMENT ─ */
.announce{background:var(--rose);height:36px;display:flex;align-items:center;justify-content:center;font-size:.48rem;letter-spacing:.4em;color:rgba(245,239,232,.9);font-weight:100;position:relative;z-index:201}
 
/* ═══════════════ HOME PAGE ═══════════════ */
 
/* Hero */
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden;text-align:center;padding:0 40px;padding-top:104px}
.hero-blob{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none}
.blob-r{width:550px;height:550px;background:radial-gradient(ellipse,rgba(139,58,82,.22) 0%,transparent 70%);top:-8%;right:-4%;animation:bd 14s ease-in-out infinite}
.blob-g{width:380px;height:380px;background:radial-gradient(ellipse,rgba(201,169,110,.09) 0%,transparent 70%);bottom:4%;left:-4%;animation:bd 18s ease-in-out infinite reverse}
@keyframes bd{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(25px,-18px) scale(1.04)}}
.hero::before{content:'';position:absolute;inset:-50%;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");opacity:.35;pointer-events:none;animation:grain 8s steps(2) infinite}
@keyframes grain{0%,100%{transform:translate(0,0)}25%{transform:translate(-2%,-3%)}50%{transform:translate(3%,2%)}75%{transform:translate(-1%,4%)}}
 
.hero-inner{position:relative;z-index:2}
.hero-eyebrow{font-size:.5rem;letter-spacing:.52em;color:var(--gold);font-weight:100;margin-bottom:28px;opacity:0;animation:fu .8s .3s forwards;display:flex;align-items:center;justify-content:center;gap:14px}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:36px;height:1px;background:rgba(201,169,110,.4)}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(5.5rem,15vw,13rem);font-weight:300;letter-spacing:.18em;color:var(--cream);line-height:.88;opacity:0;animation:fu 1s .5s forwards}
.hero-title em{font-style:italic;color:var(--gold);display:block;font-size:.68em;letter-spacing:.1em;margin-top:6px}
.hero-sub{font-size:.55rem;letter-spacing:.42em;color:#4a3a3a;font-weight:100;margin:26px 0 52px;opacity:0;animation:fu .8s .8s forwards}
.hero-ctas{display:flex;align-items:center;gap:26px;justify-content:center;opacity:0;animation:fu .8s 1s forwards}
.btn-p{padding:15px 42px;background:var(--gold);color:var(--dark2);font-size:.5rem;letter-spacing:.38em;font-weight:300;text-decoration:none;transition:all .3s;cursor:none;border:none;font-family:'Josefin Sans',sans-serif}
.btn-p:hover{background:var(--cream)}
.btn-gh{font-size:.5rem;letter-spacing:.38em;color:#666;text-decoration:none;transition:color .3s;cursor:none;display:flex;align-items:center;gap:8px;background:none;border:none;font-family:'Josefin Sans',sans-serif}
.btn-gh::after{content:'→';color:var(--gold);transition:transform .3s}
.btn-gh:hover{color:var(--cream)}
.btn-gh:hover::after{transform:translateX(4px)}
.hero-scroll{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:7px;opacity:0;animation:fadeIn 1s 1.6s forwards;z-index:2}
.scroll-line{width:1px;height:52px;background:linear-gradient(to bottom,transparent,rgba(201,169,110,.5));animation:sp 2s ease-in-out infinite}
@keyframes sp{0%,100%{opacity:.3}50%{opacity:1}}
.scroll-txt{font-size:.4rem;letter-spacing:.42em;color:#333}
@keyframes fu{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
 
/* Marquee */
.marquee{border-top:1px solid #181818;border-bottom:1px solid #181818;padding:14px 0;overflow:hidden;background:var(--dark2)}
.m-track{display:flex;gap:52px;animation:mq 24s linear infinite;white-space:nowrap}
.m-track span{font-size:.46rem;letter-spacing:.52em;color:#2e2e2e;flex-shrink:0}
.m-track .dot{color:var(--gold)}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}
 
/* Featured */
.featured{padding:110px 52px;background:var(--bg)}
.sec-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:60px}
.sec-ey{font-size:.47rem;letter-spacing:.48em;color:var(--gold);font-weight:100;margin-bottom:12px;display:flex;align-items:center;gap:12px}
.sec-ey::before{content:'';width:18px;height:1px;background:var(--gold);opacity:.6}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:300;color:var(--cream)}
.sec-title em{font-style:italic;color:var(--gold)}
.see-all{font-size:.46rem;letter-spacing:.38em;color:#444;text-decoration:none;cursor:none;display:flex;align-items:center;gap:8px;transition:color .3s}
.see-all::after{content:'→';color:var(--gold);transition:transform .3s}
.see-all:hover{color:var(--gold)}
.see-all:hover::after{transform:translateX(4px)}
 
.prod-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.prod-card{background:var(--mid);position:relative;overflow:hidden;cursor:none}
.prod-card:first-child{grid-row:span 2}
.prod-img{aspect-ratio:3/4;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.prod-card:first-child .prod-img{aspect-ratio:unset;height:100%}
.prod-bg{position:absolute;inset:0;transition:transform .7s ease}
.prod-card:hover .prod-bg{transform:scale(1.05)}
.prod-bg-1{background:radial-gradient(ellipse at 55% 35%,rgba(139,58,82,.32) 0%,transparent 60%),linear-gradient(165deg,#201414 0%,#0e0909 100%)}
.prod-bg-2{background:radial-gradient(ellipse at 40% 60%,rgba(201,169,110,.18) 0%,transparent 55%),linear-gradient(195deg,#1c1515 0%,#0c0909 100%)}
.prod-bg-3{background:radial-gradient(ellipse at 65% 40%,rgba(139,58,82,.2) 0%,transparent 50%),linear-gradient(145deg,#1a1212 0%,#0d0a0a 100%)}
.prod-bg-4{background:radial-gradient(ellipse at 35% 55%,rgba(201,169,110,.14) 0%,transparent 55%),linear-gradient(175deg,#181212 0%,#0b0909 100%)}
 
.prod-moon{position:absolute;opacity:.55}
.prod-info{padding:24px 28px;position:relative;z-index:2}
.prod-tag{font-size:.42rem;letter-spacing:.42em;color:var(--gold);font-weight:100;margin-bottom:7px}
.prod-name{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:300;color:var(--cream);margin-bottom:5px}
.prod-name em{font-style:italic}
.prod-price{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--gold);font-weight:300}
.prod-hover{position:absolute;bottom:0;left:0;right:0;background:rgba(201,169,110,.92);padding:14px;display:flex;justify-content:center;transform:translateY(100%);transition:transform .35s ease}
.prod-card:hover .prod-hover{transform:translateY(0)}
.prod-hover-btn{font-size:.46rem;letter-spacing:.38em;color:var(--dark2);font-weight:300;background:none;border:none;cursor:none;font-family:'Josefin Sans',sans-serif}
 
/* Brand story */
.story{display:grid;grid-template-columns:1fr 1fr;background:var(--dark2)}
.story-visual{position:relative;min-height:580px;display:flex;align-items:center;justify-content:center;overflow:hidden}
.story-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 45%,rgba(139,58,82,.2) 0%,transparent 65%)}
.story-moon-wrap{position:relative;z-index:2}
.story-text{padding:90px 68px;display:flex;flex-direction:column;justify-content:center}
.story-body{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--muted);line-height:1.95;font-weight:300;margin:28px 0 44px}
.story-stats{display:flex;gap:40px;padding-top:32px;border-top:1px solid #1e1e1e}
.stat-n{font-family:'Cormorant Garamond',serif;font-size:2.6rem;color:var(--gold);font-weight:300;line-height:1}
.stat-l{font-size:.44rem;letter-spacing:.38em;color:#3a2a2a;margin-top:6px}
 
/* Testimonials */
.testi{padding:100px 0;background:var(--bg);overflow:hidden}
.testi-head{padding:0 52px;margin-bottom:52px}
.t-track{display:flex;gap:20px;animation:ts 28s linear infinite}
.t-track:hover{animation-play-state:paused}
@keyframes ts{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.t-card{flex-shrink:0;width:360px;background:var(--mid);border:1px solid #1e1e1e;padding:36px;position:relative}
.t-card::before{content:'"';position:absolute;top:16px;right:22px;font-family:'Cormorant Garamond',serif;font-size:4.5rem;color:rgba(201,169,110,.08);line-height:1}
.t-text{font-family:'Cormorant Garamond',serif;font-size:1rem;font-style:italic;color:#8a7070;line-height:1.85;font-weight:300;margin-bottom:24px}
.t-auth{display:flex;align-items:center;gap:12px}
.t-av{width:32px;height:32px;border-radius:50%;background:var(--rose);opacity:.65;display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:.85rem;color:var(--cream);flex-shrink:0}
.t-name{font-size:.46rem;letter-spacing:.28em;color:var(--cream)}
.t-stars{color:var(--gold);font-size:.5rem;margin-top:3px}
 
/* Newsletter */
.nl{padding:120px 52px;background:var(--mid);text-align:center;position:relative;overflow:hidden}
.nl::before{content:'LUNE';position:absolute;font-family:'Cormorant Garamond',serif;font-size:28vw;font-weight:300;color:rgba(201,169,110,.022);top:50%;left:50%;transform:translate(-50%,-50%);white-space:nowrap;pointer-events:none;line-height:1}
.nl-title{font-family:'Cormorant Garamond',serif;font-size:clamp(2.2rem,5vw,4.2rem);font-weight:300;color:var(--cream);line-height:1.1;margin-bottom:16px;position:relative;z-index:1}
.nl-title em{font-style:italic;color:var(--gold)}
.nl-sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.05rem;color:var(--muted);margin-bottom:48px;position:relative;z-index:1}
.nl-form{display:flex;justify-content:center;gap:0;max-width:460px;margin:0 auto;position:relative;z-index:1}
.nl-input{flex:1;padding:15px 22px;background:var(--bg);border:1px solid #222;border-right:none;color:var(--cream);font-family:'Josefin Sans',sans-serif;font-size:.5rem;letter-spacing:.22em;font-weight:100;outline:none}
.nl-input::placeholder{color:#2a2a2a}
.nl-btn{padding:15px 28px;background:var(--gold);border:none;color:var(--dark2);font-family:'Josefin Sans',sans-serif;font-size:.48rem;letter-spacing:.38em;font-weight:300;cursor:none;transition:background .3s}
.nl-btn:hover{background:var(--cream)}
 
/* ═══════════════ COLLECTION PAGE ═══════════════ */
.coll-hero{padding:160px 52px 80px;text-align:center;position:relative;overflow:hidden;background:var(--dark2)}
.coll-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%,rgba(139,58,82,.16) 0%,transparent 60%)}
.coll-hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,8vw,6.5rem);font-weight:300;letter-spacing:.12em;color:var(--cream);position:relative;z-index:1}
.coll-hero-title em{font-style:italic;color:var(--gold)}
.coll-filters{display:flex;gap:0;justify-content:center;padding:48px 52px 36px;border-bottom:1px solid #181818}
.filter-btn{background:none;border:none;border-bottom:2px solid transparent;color:#444;font-family:'Josefin Sans',sans-serif;font-size:.5rem;letter-spacing:.38em;padding:10px 26px;cursor:none;transition:all .3s}
.filter-btn.active,.filter-btn:hover{color:var(--cream);border-bottom-color:var(--gold)}
.coll-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;padding:2px}
.coll-card{background:var(--mid);position:relative;cursor:none;overflow:hidden}
.coll-card-img{aspect-ratio:3/4;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.coll-card-bg{position:absolute;inset:0;transition:transform .6s ease}
.coll-card:hover .coll-card-bg{transform:scale(1.04)}
.coll-card-info{padding:22px 26px 28px}
.coll-card-cat{font-size:.42rem;letter-spacing:.42em;color:var(--gold);font-weight:100;margin-bottom:6px}
.coll-card-name{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:300;color:var(--cream);margin-bottom:4px}
.coll-card-price{font-family:'Cormorant Garamond',serif;font-size:.95rem;color:var(--gold);font-weight:300}
.coll-card-add{position:absolute;bottom:22px;right:22px;width:38px;height:38px;border:1px solid rgba(201,169,110,.3);background:none;display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:.9rem;cursor:none;transition:all .3s;opacity:0}
.coll-card:hover .coll-card-add{opacity:1}
.coll-card-add:hover{background:var(--gold);color:var(--dark2)}
.coll-card-badge{position:absolute;top:18px;left:18px;background:var(--rose);padding:5px 12px;font-size:.4rem;letter-spacing:.35em;color:var(--cream)}
 
/* ═══════════════ PRODUCT PAGE ═══════════════ */
.prod-page{padding:100px 52px 80px}
.prod-layout{display:grid;grid-template-columns:1.1fr .9fr;gap:60px;align-items:start}
.prod-gallery{position:sticky;top:90px}
.prod-main-img{aspect-ratio:3/4;background:var(--mid);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;margin-bottom:12px}
.prod-thumbs{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.thumb{aspect-ratio:1;background:var(--mid);cursor:none;border:1px solid transparent;transition:border-color .3s;overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center}
.thumb.active,.thumb:hover{border-color:var(--gold)}
.prod-details{}
.prod-d-tag{font-size:.46rem;letter-spacing:.45em;color:var(--gold);font-weight:100;margin-bottom:14px}
.prod-d-name{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,4vw,3rem);font-weight:300;color:var(--cream);line-height:1.05;margin-bottom:10px}
.prod-d-name em{font-style:italic;color:var(--gold)}
.prod-d-price{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--gold);font-weight:300;margin-bottom:28px}
.prod-d-divider{width:60px;height:1px;background:rgba(201,169,110,.35);margin-bottom:28px}
.prod-d-desc{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--muted);line-height:1.9;font-weight:300;margin-bottom:36px}
.size-label{font-size:.46rem;letter-spacing:.38em;color:#666;margin-bottom:14px}
.sizes{display:flex;gap:8px;margin-bottom:32px;flex-wrap:wrap}
.size-btn{width:44px;height:44px;border:1px solid #2a2a2a;background:none;color:#666;font-family:'Josefin Sans',sans-serif;font-size:.5rem;cursor:none;transition:all .3s}
.size-btn.active,.size-btn:hover{border-color:var(--gold);color:var(--cream)}
.size-btn.active{background:var(--gold);color:var(--dark2)}
.add-cart-btn{width:100%;padding:17px;background:var(--gold);border:none;color:var(--dark2);font-family:'Josefin Sans',sans-serif;font-size:.52rem;letter-spacing:.42em;font-weight:300;cursor:none;margin-bottom:14px;transition:background .3s}
.add-cart-btn:hover{background:var(--cream)}
.wishlist-btn{width:100%;padding:14px;background:none;border:1px solid #222;color:#555;font-family:'Josefin Sans',sans-serif;font-size:.5rem;letter-spacing:.38em;cursor:none;transition:all .3s}
.wishlist-btn:hover{border-color:rgba(201,169,110,.4);color:var(--cream)}
.prod-features{margin-top:36px;border-top:1px solid #1a1a1a;padding-top:28px;display:flex;flex-direction:column;gap:16px}
.feat{display:flex;align-items:center;gap:14px}
.feat-icon{width:32px;height:32px;border:1px solid rgba(201,169,110,.2);display:flex;align-items:center;justify-content:center;font-size:.7rem;color:var(--gold);flex-shrink:0}
.feat-text{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:var(--muted)}
.prod-accord{margin-top:32px}
.accord-item{border-top:1px solid #1a1a1a}
.accord-btn{width:100%;background:none;border:none;color:var(--cream);font-family:'Josefin Sans',sans-serif;font-size:.5rem;letter-spacing:.35em;padding:18px 0;display:flex;justify-content:space-between;align-items:center;cursor:none;transition:color .3s}
.accord-btn:hover{color:var(--gold)}
.accord-content{display:none;padding-bottom:18px}
.accord-content p{font-family:'Cormorant Garamond',serif;font-size:.92rem;color:var(--muted);line-height:1.8}
.accord-item.open .accord-content{display:block}
.accord-item.open .accord-btn{color:var(--gold)}
 
/* ═══════════════ CART PAGE ═══════════════ */
.cart-page{min-height:100vh;padding:120px 52px 80px}
.cart-layout{display:grid;grid-template-columns:1.3fr .7fr;gap:60px;align-items:start}
.cart-title{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:var(--cream);margin-bottom:48px}
.cart-title em{font-style:italic;color:var(--gold)}
.cart-items{display:flex;flex-direction:column;gap:0}
.cart-item{display:grid;grid-template-columns:100px 1fr auto;gap:24px;padding:28px 0;border-bottom:1px solid #181818;align-items:center}
.cart-item-img{aspect-ratio:1;background:var(--mid);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.cart-item-info{}
.cart-item-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;color:var(--cream);margin-bottom:5px}
.cart-item-name em{font-style:italic;color:var(--gold)}
.cart-item-meta{font-size:.44rem;letter-spacing:.3em;color:#444;margin-bottom:12px}
.cart-qty{display:flex;align-items:center;gap:0;width:fit-content}
.qty-btn{width:32px;height:32px;border:1px solid #2a2a2a;background:none;color:#666;cursor:none;font-size:.9rem;transition:all .3s;display:flex;align-items:center;justify-content:center}
.qty-btn:hover{border-color:var(--gold);color:var(--cream)}
.qty-val{width:40px;height:32px;border-top:1px solid #2a2a2a;border-bottom:1px solid #2a2a2a;display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--cream)}
.cart-item-price{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--gold);text-align:right}
.cart-remove{font-size:.42rem;letter-spacing:.3em;color:#333;cursor:none;background:none;border:none;font-family:'Josefin Sans',sans-serif;transition:color .3s;margin-top:8px;display:block}
.cart-remove:hover{color:var(--rose)}
 
.cart-summary{background:var(--mid);padding:40px;position:sticky;top:90px}
.summary-title{font-size:.5rem;letter-spacing:.45em;color:var(--gold);margin-bottom:28px}
.summary-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.summary-label{font-family:'Cormorant Garamond',serif;font-size:.95rem;color:var(--muted)}
.summary-val{font-family:'Cormorant Garamond',serif;font-size:.95rem;color:var(--cream)}
.summary-divider{height:1px;background:#1e1e1e;margin:20px 0}
.summary-total-label{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--cream)}
.summary-total-val{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--gold)}
.checkout-btn{width:100%;padding:18px;background:var(--gold);border:none;color:var(--dark2);font-family:'Josefin Sans',sans-serif;font-size:.52rem;letter-spacing:.42em;margin-top:24px;cursor:none;transition:background .3s}
.checkout-btn:hover{background:var(--cream)}
.summary-note{font-size:.44rem;letter-spacing:.28em;color:#2a2a2a;text-align:center;margin-top:14px}
.promo-row{display:flex;gap:0;margin:24px 0}
.promo-input{flex:1;padding:12px 16px;background:var(--bg);border:1px solid #222;border-right:none;color:var(--cream);font-family:'Josefin Sans',sans-serif;font-size:.46rem;letter-spacing:.2em;outline:none}
.promo-btn{padding:12px 18px;background:none;border:1px solid #222;color:#555;font-family:'Josefin Sans',sans-serif;font-size:.44rem;letter-spacing:.3em;cursor:none;transition:all .3s}
.promo-btn:hover{border-color:var(--gold);color:var(--gold)}
 
/* ═══════════════ ABOUT PAGE ═══════════════ */
.about-hero{min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:140px 52px 100px;background:var(--dark2);position:relative;overflow:hidden}
.about-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(139,58,82,.15) 0%,transparent 65%)}
.about-hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,8vw,7rem);font-weight:300;color:var(--cream);position:relative;z-index:1}
.about-hero-title em{font-style:italic;color:var(--gold);display:block}
.about-content{padding:100px 52px}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;margin-bottom:100px}
.about-img-box{aspect-ratio:4/5;background:var(--mid);position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
.about-text-block{}
.ab-body{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--muted);line-height:1.95;font-weight:300;margin:24px 0 36px}
.values-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:60px}
.value-card{background:var(--mid);padding:36px;border:1px solid #1a1a1a;position:relative}
.value-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--gold);opacity:.4}
.value-num{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:var(--gold);margin-bottom:12px}
.value-title{font-size:.5rem;letter-spacing:.38em;color:var(--cream);margin-bottom:10px}
.value-desc{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:var(--muted);line-height:1.7}
.team-section{padding:80px 52px;background:var(--dark2);text-align:center}
.team-quote{font-family:'Cormorant Garamond',serif;font-size:clamp(1.5rem,3.5vw,2.5rem);font-style:italic;color:var(--cream);line-height:1.5;max-width:700px;margin:40px auto 0}
 
/* ═══════════════ CONTACT PAGE ═══════════════ */
.contact-page{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;padding-top:68px}
.contact-left{background:var(--mid);padding:100px 60px;display:flex;flex-direction:column;justify-content:center;position:relative;overflow:hidden}
.contact-left::before{content:'';position:absolute;top:-100px;right:-80px;width:320px;height:320px;border-radius:50%;background:radial-gradient(ellipse,rgba(139,58,82,.15) 0%,transparent 70%)}
.contact-right{background:var(--bg);padding:100px 60px;display:flex;flex-direction:column;justify-content:center}
.contact-h{font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:var(--cream);margin-bottom:36px}
.contact-h em{font-style:italic;color:var(--gold);display:block}
.contact-info{display:flex;flex-direction:column;gap:24px;margin-top:48px}
.c-info-item{display:flex;align-items:flex-start;gap:18px}
.c-icon{width:36px;height:36px;border:1px solid rgba(201,169,110,.2);display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:.75rem;flex-shrink:0;margin-top:2px}
.c-info-label{font-size:.44rem;letter-spacing:.35em;color:var(--gold);margin-bottom:6px}
.c-info-val{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--muted)}
.form-group{margin-bottom:20px}
.form-label{font-size:.45rem;letter-spacing:.38em;color:#444;display:block;margin-bottom:9px}
.form-input,.form-textarea{width:100%;padding:13px 18px;background:var(--mid);border:1px solid #1e1e1e;color:var(--cream);font-family:'Josefin Sans',sans-serif;font-size:.5rem;letter-spacing:.18em;outline:none;transition:border-color .3s}
.form-input:focus,.form-textarea:focus{border-color:rgba(201,169,110,.4)}
.form-textarea{height:130px;resize:none}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-submit{width:100%;padding:16px;background:var(--gold);border:none;color:var(--dark2);font-family:'Josefin Sans',sans-serif;font-size:.5rem;letter-spacing:.42em;cursor:none;margin-top:8px;transition:background .3s}
.form-submit:hover{background:var(--cream)}
 
/* ─ FOOTER ─ */
footer{background:#060506;border-top:1px solid #111;padding:72px 52px 36px}
.footer-top{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:52px;margin-bottom:60px}
.f-brand{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;letter-spacing:.38em;color:var(--cream);margin-bottom:16px}
.f-desc{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:#3a2a2a;line-height:1.85;font-weight:300;max-width:240px}
.f-col h4{font-size:.46rem;letter-spacing:.42em;color:var(--gold);font-weight:100;margin-bottom:20px}
.f-col ul{list-style:none;display:flex;flex-direction:column;gap:11px}
.f-col a{font-family:'Cormorant Garamond',serif;font-size:.9rem;color:#3a2a2a;text-decoration:none;transition:color .3s;cursor:none}
.f-col a:hover{color:var(--cream)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;border-top:1px solid #111;padding-top:24px}
.f-copy{font-size:.42rem;letter-spacing:.32em;color:#222}
.f-social{display:flex;gap:22px}
.f-social a{font-size:.42rem;letter-spacing:.32em;color:#222;text-decoration:none;transition:color .3s;cursor:none}
.f-social a:hover{color:var(--gold)}
 
/* ─ TOAST ─ */
.toast{position:fixed;bottom:40px;right:40px;background:var(--gold);color:var(--dark2);padding:14px 28px;font-size:.48rem;letter-spacing:.35em;z-index:1000;transform:translateY(100px);opacity:0;transition:all .4s;pointer-events:none}
.toast.show{transform:translateY(0);opacity:1}
 
/* ─ REVEAL ─ */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s ease,transform .7s ease}
.reveal.vis{opacity:1;transform:translateY(0)}
 
/* ─ MOBILE ─ */
@media(max-width:900px){
  nav{padding:0 24px}
  .nav-links{display:none}
  .hero-title{font-size:clamp(4rem,18vw,7rem)}
  .featured,.coll-hero,.testi-head,.nl,.about-content,.contact-page,.prod-page,.cart-page,.team-section{padding-left:24px;padding-right:24px}
  .prod-grid{grid-template-columns:1fr 1fr}
  .prod-card:first-child{grid-row:unset}
  .coll-grid{grid-template-columns:1fr 1fr}
  .story,.about-grid,.prod-layout,.cart-layout,.contact-page{grid-template-columns:1fr}
  .footer-top{grid-template-columns:1fr 1fr}
  .cart-item{grid-template-columns:80px 1fr auto}
  .form-row{grid-template-columns:1fr}
}
</style>
</head>
